{
    "name": "auto-attendance-form",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "wxt",
        "dev:firefox": "wxt -b firefox",
        "build:fonts": "node scripts/convert-fonts.js",
        "build:chrome": "wxt build && node scripts/copyOutput.js chrome",
        "build:firefox": "wxt build -b firefox && node scripts/copyOutput.js firefox",
        "build:all": "bun run build:fonts && bun run build:chrome && bun run build:firefox",
        "build": "bun run build:all",
        "zip": "wxt zip",
        "zip:firefox": "wxt zip -b firefox",
        "sign:firefox": "web-ext sign --source-dir=dist/firefox --artifacts-dir=build/signed",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "tsc": "tsc --noEmit",
        "postinstall": "wxt prepare"
    },
    "dependencies": {
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "webextension-polyfill": "^0.12.0"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.1.18",
        "@types/chrome": "^0.1.36",
        "@types/react": "^19.2.10",
        "@types/react-dom": "^19.2.3",
        "@typescript-eslint/eslint-plugin": "^8.54.0",
        "@typescript-eslint/parser": "^8.54.0",
        "autoprefixer": "^10.4.23",
        "esbuild": "^0.27.2",
        "eslint": "9.39.1",
        "fs-extra": "^11.3.3",
        "oxlint": "^1.42.0",
        "postcss": "^8.5.6",
        "tailwindcss": "^4.1.18",
        "ttf2woff2": "^8.0.0",
        "typescript": "^5.9.3",
        "web-ext": "^9.2.0",
        "wxt": "^0.20.13"
    }
}
